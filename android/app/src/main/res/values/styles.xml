<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <!-- Little Explorer Academy brand colors -->
        <item name="colorPrimary">#7C3AED</item>
        <item name="colorPrimaryDark">#5B21B6</item>
        <item name="colorAccent">#F59E0B</item>
    </style>

    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:background">@null</item>
        <item name="android:fitsSystemWindows">true</item>
        <item name="android:statusBarColor">#00000000</item>
    </style>

    <!-- Splash screen using AndroidX SplashScreen API (core-splashscreen 1.2.x) -->
    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#7C3AED</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_icon</item>
        <item name="postSplashScreenTheme">@style/AppTheme.NoActionBar</item>
    </style>

</resources>